<Window x:Class="UkProxyMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="420" Width="780"
        Background="Black" Foreground="Cyan"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Text="VPS Host (IP)" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" x:Name="VpsHostBox" FontFamily="Consolas"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Text="VPS User" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,8" x:Name="VpsUserBox" FontFamily="Consolas"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" Text="SSH Key Path" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,8,8" x:Name="KeyPathBox" FontFamily="Consolas"/>
        <Button Grid.Row="2" Grid.Column="2" Margin="0,0,0,8" Content="Browse..." Click="BrowseKey_Click"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" Text="SOCKS Port" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,8,8" x:Name="SocksPortBox" FontFamily="Consolas"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" Text="IPinfo Token (optional)" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,8,8" x:Name="IpinfoTokenBox" FontFamily="Consolas"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="-2,24,10,0" Text="Monitor Interval (sec)" VerticalAlignment="Top" Grid.RowSpan="2"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,24,8,187" x:Name="IntervalBox" FontFamily="Consolas" Grid.RowSpan="2"/>
      
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="120" Margin="0,10,10,0" Content="Cancel" Click="Cancel_Click"/>
            <Button Width="120" Margin="0,10,0,0" Content="Save" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
