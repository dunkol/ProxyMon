<Window x:Class="UkProxyMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proxy Monitor"
        Height="780"
        Width="1100"
        Background="Black">

    <DockPanel LastChildFill="True">

        <!-- Top menu -->
        <Menu DockPanel.Dock="Top"
              Background="#F0F0F0"
              Foreground="Black">
            <MenuItem Header="_File">
                <MenuItem Header="Save _Logs" Click="SaveLogs_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Actions">
                <MenuItem Header="_Start" Click="Start_Click"/>
                <MenuItem Header="S_top" Click="Stop_Click"/>
            </MenuItem>

            <MenuItem Header="_Settings">
                <MenuItem Header="_Configure" Click="Configure_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main content -->
        <Grid Margin="8" Background="Black">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar row -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="90"
                        Height="28"
                        Content="Start"
                        Click="Start_Click"/>

                <Button Grid.Column="2"
                        Width="90"
                        Height="28"
                        Content="Stop"
                        Click="Stop_Click"/>

                <CheckBox Grid.Column="4"
                  x:Name="AutoStartVpsCheckBox"
                  Content="Autostart VPS"
                  Foreground="Cyan"
                  VerticalAlignment="Center"
                  IsChecked="False"/>

                        <TextBlock Grid.Column="5"
                   x:Name="StatusText"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Foreground="Cyan"
                   Text="Idle"/>
                    </Grid>

                    <!-- SSH section -->
            <GroupBox Grid.Row="2"
                      Header="SSH Tunnel Output"
                      Foreground="Cyan"
                      BorderBrush="#A0A0A0"
                      Background="Black"
                      Padding="4">
                <TextBox x:Name="SshLog"
                         Background="Black"
                         Foreground="Cyan"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="14"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </GroupBox>

            <!-- Monitor section -->
            <GroupBox Grid.Row="4"
                      Header="Monitor Output"
                      Foreground="Cyan"
                      BorderBrush="#A0A0A0"
                      Background="Black"
                      Padding="4">
                <RichTextBox x:Name="MonitorLog"
                         Background="Black"
                         Foreground="Cyan"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="14"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>