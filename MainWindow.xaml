<Window x:Class="UkProxyMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proxy Monitor" Height="780" Width="1100"
        Background="Black" Foreground="Cyan">
    <DockPanel>

        <Menu DockPanel.Dock="Top" Background="White" Foreground="Black">
            <MenuItem Header="_File">
                <MenuItem Header="_Save Logs..." Click="SaveLogs_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Actions">
                <MenuItem Header="_Start" Click="Start_Click"/>
                <MenuItem Header="S_top" Click="Stop_Click"/>
                <MenuItem Header="_Actions" Foreground="Black">
                    <MenuItem Header="_Gateway" x:Name="GatewayMenuRoot">
                        <!-- populated dynamically -->
                    </MenuItem>
                </MenuItem>

            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Configure..." Click="Configure_Click"/>
            </MenuItem>
        </Menu>

        <StackPanel Margin="10">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Start" Width="120" Margin="0,0,10,0" Click="Start_Click"/>
                <Button Content="Stop" Width="120" Margin="0,0,10,0" Click="Stop_Click"/>
                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                <TextBlock x:Name="StatusText" Text="Idle" VerticalAlignment="Center" Foreground="LightGreen"/>
                <TextBlock x:Name="GatewayStatusText" Text="Gateway: Stopped" Margin="12,0,0,0"/>

                <TextBlock Width="80" VerticalAlignment="Center" Margin="10,0,5,0">
                        <Run Text="Warnings: "/>
                        <Run x:Name="WarningsText" Text="0" Foreground="Yellow"/>
                    </TextBlock>

                <TextBlock Width="80" VerticalAlignment="Center" Margin="0,0,5,0">
                        <Run Text="Errors: "/>
                        <Run x:Name="ErrorsText" Text="0" Foreground="Red"/>
                    </TextBlock>

            </StackPanel>

            <TextBlock Text="SSH Tunnel Output" FontWeight="Bold" Margin="0,0,0,5"/>
            <RichTextBox x:Name="SshLog"
             Height="290"
             Background="Black"
             Foreground="Cyan"
             FontFamily="Consolas"
             FontSize="13"
             IsReadOnly="True"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"/>

            <TextBlock Text="Monitor Output" FontWeight="Bold" Margin="0,12,0,5"/>

            <RichTextBox x:Name="MonitorLog"
             Height="320"
             Background="Black"
             Foreground="Cyan"
             FontFamily="Consolas"
             FontSize="13"
             IsReadOnly="True"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"/>

        </StackPanel>

        <Border DockPanel.Dock="Bottom"
        Background="#111"
        Padding="6"
        BorderThickness="1,1,0,0"
        BorderBrush="#333">

            <TextBlock x:Name="FooterText"
               FontFamily="Consolas"
               FontSize="12"
               Foreground="DarkCyan"
               HorizontalAlignment="Center"/>
        </Border>
    </DockPanel>
</Window>

