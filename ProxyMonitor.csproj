<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\AppIcon_multisize.ico</ApplicationIcon>
    <Title>Proxy Monitor</Title>
    <Version>$(VersionPrefix)1</Version>
    <Company>$(Authors)Ortino Limited</Company>
    <Copyright>Copyright 2006 Ortino Limited, all rights reserved.</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\AppIcon_multisize.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Renci.SshNet.Async" Version="1.4.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Assets\ringtone-1-46486.mp3">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
